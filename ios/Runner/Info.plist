	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>ru</string>
		<string>en</string>
		<string>es</string>
		<string>zh</string>
		<string>hi</string>
		<string>ar</string>
		<string>pt</string>
		<string>fr</string>
		<string>de</string>
		<string>ja</string>
		<string>ko</string>
		<string>it</string>
